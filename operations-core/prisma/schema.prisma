generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum Role {
  OWNER
  ADMIN
  STAFF
  MODERATOR
  MEMBER
  USER
  GUEST
}

enum AppType {
  WARETRACK
  MPLOYEE
  CODIGRAM
  LEATHER_SHELF
  PINEAPPLE_STACK
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

enum MovementType {
  PURCHASE
  SALE
  TRANSFER
  ADJUSTMENT
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum DocumentType {
  KTP
  PASSPORT
  NPWP
  CV
  CERTIFICATE
  OTHER
}

enum ReactionType {
  LIKE
  LOVE
  HELPFUL
  INSIGHTFUL
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// SHARED

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String
  role      Role
  isActive  Boolean        @default(true)
  lastLogin DateTime?
  profile   Profile?
  wareTrack UserWareTrack?
  mployee   UserMployee?
  codigram  UserCodigram?
  leather   UserLeather?
  pineapple UserPineapple?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("users")
}

model Profile {
  id         String    @id @default(uuid())
  userId     String    @unique
  firstName  String?
  lastName   String?
  phone      String?
  gender     String?
  birthDate  DateTime?
  avatar     String?
  bio        String?
  address    String?
  city       String?
  province   String?
  country    String?
  postalCode String?
  website    String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("profiles")
}

// USER - WARETRACK

model UserWareTrack {
  id           String     @id @default(uuid())
  userId       String     @unique
  employeeCode String?
  warehouseId  String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("user_waretracks")
}

// USER - M-PLOYEE

model UserMployee {
  id         String   @id @default(uuid())
  userId     String   @unique
  employeeId String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("user_mployees")
}

// USER - CODIGRAM

model UserCodigram {
  id          String    @id @default(uuid())
  userId      String    @unique
  username    String    @unique
  displayName String
  bio         String?
  verified    Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]
  comments    Comment[]
  likes       Like[]
  following   Follow[]  @relation("Follower")
  followers   Follow[]  @relation("Following")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("user_codigrams")
}

// USER - LEATHER SHELF

model UserLeather {
  id               String   @id @default(uuid())
  userId           String   @unique
  membershipNumber String?  @unique
  favoriteGenre    String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user_leathers")
}

// USER - PINEAPPLE STACK

model UserPineapple {
  id         String      @id @default(uuid())
  userId     String      @unique
  reputation Int         @default(0)
  signature  String?
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics     Topic[]
  posts      ForumPost[]
  replies    Reply[]
  reactions  Reaction[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("user_pineapples")
}

// IMAGES

model Image {
  id        String   @id @default(uuid())
  appType   AppType
  entity    String
  entityId  String
  url       String
  publicId  String
  alt       String?
  createdAt DateTime @default(now())

  @@index([appType])
  @@index([entity, entityId])
  @@map("images")
}

// WARETRACK

model Category {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?
  icon        String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("brands")
}

model Product {
  id            String         @id @default(uuid())
  categoryId    String
  brandId       String?
  sku           String         @unique
  barcode       String?        @unique
  name          String
  description   String?
  unit          String
  costPrice     Decimal        @db.Decimal(12, 2)
  sellingPrice  Decimal        @db.Decimal(12, 2)
  minimumQty    Int            @default(0)
  maximumQty    Int?
  isActive      Boolean        @default(true)
  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  stocks        Stock[]
  purchaseItems PurchaseItem[]
  transferItems TransferItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("products")
}

model Warehouse {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  address        String?
  capacity       Int
  locations      Location[]
  stocks         Stock[]
  outgoing       Transfer[]      @relation("FromWarehouse")
  incoming       Transfer[]      @relation("ToWarehouse")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userWareTracks UserWareTrack[]

  @@map("warehouses")
}

model Location {
  id          String    @id @default(uuid())
  warehouseId String
  code        String    @unique
  name        String
  capacity    Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  stocks      Stock[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("locations")
}

model Stock {
  id          String     @id @default(uuid())
  warehouseId String
  locationId  String?
  productId   String
  quantity    Int        @default(0)
  reserved    Int        @default(0)
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  location    Location?  @relation(fields: [locationId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
  movements   Movement[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([warehouseId, productId])
  @@map("stocks")
}

model Movement {
  id        String       @id @default(uuid())
  stockId   String
  type      MovementType
  quantity  Int
  beforeQty Int
  afterQty  Int
  reference String?
  remarks   String?
  stock     Stock        @relation(fields: [stockId], references: [id])
  createdAt DateTime     @default(now())

  @@map("movements")
}

model Supplier {
  id            String     @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  website       String?
  address       String?
  logo          String?
  notes         String?
  isActive      Boolean    @default(true)
  purchases     Purchase[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("suppliers")
}

model Purchase {
  id           String         @id @default(uuid())
  supplierId   String
  invoice      String         @unique
  purchaseDate DateTime
  receivedAt   DateTime?
  status       PurchaseStatus
  total        Decimal        @db.Decimal(12, 2)
  notes        String?
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("purchases")
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  quantity   Int
  price      Decimal  @db.Decimal(12, 2)
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Transfer {
  id              String         @id @default(uuid())
  code            String         @unique
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus
  notes           String?
  fromWarehouse   Warehouse      @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse      @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  items           TransferItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(uuid())
  transferId String
  productId  String
  quantity   Int
  transfer   Transfer @relation(fields: [transferId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("transfer_items")
}

model Setting {
  id                   String   @id @default(uuid())
  warehouseName        String
  warehouseCode        String
  warehouseAddress     String
  warehouseCapacity    Int
  lowStockAlert        Boolean  @default(true)
  dailyReport          Boolean  @default(true)
  transferNotification Boolean  @default(true)
  autoBackup           Boolean  @default(true)
  sessionTimeout       Int      @default(30)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("settings")
}

// M-PLOYEE

model Department {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("departments")
}

model Position {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  category    String
  description String?
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("positions")
}

model Employee {
  id           String         @id @default(uuid())
  departmentId String
  positionId   String
  name         String
  email        String         @unique
  phone        String?
  birthDate    DateTime?
  hireDate     DateTime?
  salary       Decimal        @db.Decimal(12, 2)
  status       EmployeeStatus
  department   Department     @relation(fields: [departmentId], references: [id])
  position     Position       @relation(fields: [positionId], references: [id])
  contacts     Contact[]
  documents    Document[]
  histories    History[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userMployee  UserMployee?

  @@map("employees")
}

model Contact {
  id           String   @id @default(uuid())
  employeeId   String
  name         String
  relationship String
  phone        String
  employee     Employee @relation(fields: [employeeId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("contacts")
}

model Document {
  id         String       @id @default(uuid())
  employeeId String
  type       DocumentType
  file       String
  employee   Employee     @relation(fields: [employeeId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("documents")
}

model History {
  id         String   @id @default(uuid())
  employeeId String
  action     String
  note       String?
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())

  @@map("histories")
}

// CODIGRAM

model Post {
  id         String       @id @default(uuid())
  userId     String
  title      String
  content    String
  visibility Visibility
  user       UserCodigram @relation(fields: [userId], references: [id])
  comments   Comment[]
  likes      Like[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("posts")
}

model Comment {
  id        String       @id @default(uuid())
  userId    String
  postId    String
  content   String
  user      UserCodigram @relation(fields: [userId], references: [id])
  post      Post         @relation(fields: [postId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("comments")
}

model Like {
  id        String       @id @default(uuid())
  userId    String
  postId    String
  user      UserCodigram @relation(fields: [userId], references: [id])
  post      Post         @relation(fields: [postId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([userId, postId])
  @@map("likes")
}

model Follow {
  id          String       @id @default(uuid())
  followerId  String
  followingId String
  follower    UserCodigram @relation("Follower", fields: [followerId], references: [id])
  following   UserCodigram @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime     @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

// LEATHER SHELF

model Author {
  id String @id @default(uuid())

  name      String
  biography String?

  books BookAuthor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("authors")
}

model Publisher {
  id String @id @default(uuid())

  name String

  books Book[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("publishers")
}

model Genre {
  id String @id @default(uuid())

  name String

  books Book[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("genres")
}

model Tag {
  id String @id @default(uuid())

  name String @unique

  books BookTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tags")
}

model Book {
  id String @id @default(uuid())

  publisherId String
  genreId     String

  title String
  isbn  String @unique

  pages    Int
  language String

  description String?

  publisher Publisher @relation(fields: [publisherId], references: [id])

  genre Genre @relation(fields: [genreId], references: [id])

  authors BookAuthor[]
  tags    BookTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("books")
}

model BookAuthor {
  id String @id @default(uuid())

  bookId   String
  authorId String

  book Book @relation(fields: [bookId], references: [id])

  author Author @relation(fields: [authorId], references: [id])

  @@unique([bookId, authorId])
  @@map("book_authors")
}

model BookTag {
  id String @id @default(uuid())

  bookId String
  tagId  String

  book Book @relation(fields: [bookId], references: [id])

  tag Tag @relation(fields: [tagId], references: [id])

  @@unique([bookId, tagId])
  @@map("book_tags")
}

// PINEAPPLE STACK

model Forum {
  id          String   @id @default(uuid())
  name        String
  description String?
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("forums")
}

model Topic {
  id        String        @id @default(uuid())
  forumId   String
  userId    String
  title     String
  forum     Forum         @relation(fields: [forumId], references: [id])
  user      UserPineapple @relation(fields: [userId], references: [id])
  posts     ForumPost[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("topics")
}

model ForumPost {
  id        String        @id @default(uuid())
  topicId   String
  userId    String
  content   String
  topic     Topic         @relation(fields: [topicId], references: [id])
  user      UserPineapple @relation(fields: [userId], references: [id])
  replies   Reply[]
  reactions Reaction[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("forum_posts")
}

model Reply {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  content   String
  post      ForumPost     @relation(fields: [postId], references: [id])
  user      UserPineapple @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("replies")
}

model Reaction {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  type      ReactionType
  post      ForumPost     @relation(fields: [postId], references: [id])
  user      UserPineapple @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
  @@map("reactions")
}
